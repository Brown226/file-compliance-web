MAXKB_DB_HOST=maxkb-pgsql
MAXKB_DB_PORT=5432
MAXKB_DB_NAME=maxkb
MAXKB_DB_USER=root
MAXKB_DB_PASSWORD=Password123@postgres
MAXKB_REDIS_HOST=maxkb-redis
