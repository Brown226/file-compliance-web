<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <configSections>
    <section name="log4net" type ="log4net.Config.LogNetConfigurtionSectionHandler,log4net"/>
  </configSections>
  <log4net>
    <root>
      <level value ="ALL"/>
    </root>
    <logger name ="CommonLoger">
      <level value ="ALL"/>
      <appender-ref ref ="CommonRef" />
    </logger>
    <appender name ="CommonRef" type="log4net.Appender.RollingFileAppender,log4net">
      <param name ="File" value ="E:\Log4\"/>
      <param name ="RollingStyle" value ="Date"/>
      <param name ="AppendToFile" value ="true"/>
      <param name ="DatePattern" value ="yyyy-MM-dd&quot;log&quot;"/>
      <param name ="StaticLogFileName" value ="false"/>
      <layout type="log4net.Layout.PatternLayout,log4net">
        <param name ="ConversionPattern" value="[%d] %c - %m%n"/>
      </layout>
      <filter type ="log4net.Filter.LevelRangeFilter,log4net">
        <param name ="LeveMin" value="ALL"/>
        <param name="LeveMax" value="OFF"/>
      </filter>
    </appender>
  </log4net>
</configuration>